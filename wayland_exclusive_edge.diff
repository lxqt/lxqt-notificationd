diff -ruNp lxqt-notificationd-orig/src/notificationarea.cpp lxqt-notificationd/src/notificationarea.cpp
--- lxqt-notificationd-orig/src/notificationarea.cpp	2025-10-28 16:32:05.000000000 +0330
