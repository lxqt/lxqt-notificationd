@@ -223,6 +223,7 @@ void NotificationArea::setLayerShell()
                 }
                 layershell->setMargins(QMargins(m_spacing, m_spacing, m_spacing, m_spacing));
                 LayerShellQt::Window::Anchors anchors;
+                LayerShellQt::Window::Anchor edge = LayerShellQt::Window::AnchorTop;
                 if (QL1S("top-center") == m_placement)
                 {
                     anchors = {LayerShellQt::Window::AnchorTop};
@@ -238,24 +239,31 @@ void NotificationArea::setLayerShell()
                 else if (QL1S("center-left") == m_placement)
                 {
                     anchors = {LayerShellQt::Window::AnchorLeft};
+                    edge = LayerShellQt::Window::AnchorLeft;
                 }
                 else if (QL1S("center-right") == m_placement)
